import pandas as pd

configfile: "config/config.yaml"

# 1. read config/samples.tsv
samples_df = pd.read_csv("config/samples.tsv", sep="\t").set_index("sample_id", drop=False)

# 2. make sample_id list
SAMPLES = samples_df["sample_id"].tolist()

def get_phylogeny_targets(wildcards):
    """
    체크포인트(Phase 4)가 완료될 때까지 기다렸다가,
    생성된 interesting_loci.txt를 읽어서 최종 트리 파일 목록을 반환합니다.
    """
    # 1. 체크포인트의 출력 파일 가져오기 (이 시점에서 Phase 4가 강제로 실행됨)
    checkpoint_output = checkpoints.select_interesting_loci.get(**wildcards).output.list
    
    # 2. 파일 읽어서 유전자 ID 리스트 만들기
    with open(checkpoint_output) as f:
        targets = [line.strip() for line in f if line.strip()]
        
    # 3. 그 유전자들에 대한 트리 파일 경로 반환
    return expand("results/06_phylogeny/trees/Global_{locus}.treefile", locus=targets)

# 4. rull all
